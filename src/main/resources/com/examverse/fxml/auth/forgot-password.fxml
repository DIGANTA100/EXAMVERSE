<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.examverse.controller.auth.ForgotPasswordController"
           stylesheets="@../../css/auth.css"
           styleClass="auth-root">

    <!-- Background Gradient - Fills entire screen -->
    <VBox alignment="CENTER" styleClass="background-gradient"
          StackPane.alignment="CENTER"/>

    <!-- Card Container - Centers the forgot password card -->
    <VBox alignment="CENTER" spacing="0"
          StackPane.alignment="CENTER">

        <!-- Forgot Password Card -->
        <VBox alignment="CENTER" spacing="25" styleClass="login-card"
              maxWidth="520" minWidth="520">
            <padding>
                <Insets top="50" bottom="50" left="60" right="60"/>
            </padding>

            <!-- Header Section -->
            <VBox alignment="CENTER" spacing="10">
                <!-- Lock Icon -->
                <HBox alignment="CENTER" styleClass="logo-container">
                    <VBox alignment="CENTER" styleClass="logo-circle">
                        <padding>
                            <Insets top="22" bottom="22" left="22" right="22"/>
                        </padding>
                        <Label text="🔒" style="-fx-font-size: 32px;"/>
                    </VBox>
                </HBox>

                <!-- Title -->
                <Label text="Forgot Password?" styleClass="auth-title"/>
                <Label text="Enter your email to receive a verification code"
                       styleClass="auth-subtitle" wrapText="true"
                       textAlignment="CENTER" maxWidth="380"/>
            </VBox>

            <!-- Message Label -->
            <Label fx:id="messageLabel" text="" styleClass="message-label"
                   wrapText="true" maxWidth="400" visible="false"/>

            <!-- Form Section -->
            <VBox spacing="18" styleClass="form-section" maxWidth="400">

                <!-- Email Field -->
                <VBox spacing="8">
                    <Label text="Email Address" styleClass="field-label"/>
                    <TextField fx:id="emailField"
                               promptText="Enter your registered email"
                               styleClass="input-field">
                        <padding>
                            <Insets top="14" bottom="14" left="16" right="16"/>
                        </padding>
                    </TextField>
                </VBox>

            </VBox>

            <!-- Send Code Button -->
            <Button fx:id="sendCodeButton"
                    text="Send Verification Code"
                    styleClass="btn-login"
                    onAction="#handleSendCode"
                    maxWidth="400">
                <padding>
                    <Insets top="16" bottom="16" left="35" right="35"/>
                </padding>
            </Button>

            <!-- Info Box -->
            <VBox spacing="8" alignment="CENTER" maxWidth="400"
                  style="-fx-background-color: rgba(34, 211, 238, 0.1);
                         -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="💡 Quick Tip"
                       style="-fx-font-size: 13px; -fx-font-weight: 600;
                              -fx-text-fill: #22d3ee;"/>
                <Label text="You'll receive a 6-digit code in your email. The code expires in 10 minutes."
                       style="-fx-font-size: 12px; -fx-text-fill: #cbd5e1;
                              -fx-wrap-text: true; -fx-text-alignment: center;"
                       wrapText="true" textAlignment="CENTER"/>
            </VBox>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="12" styleClass="divider-container"
                  maxWidth="400">
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                <Label text="OR" styleClass="divider-text"/>
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Back to Login Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Remember your password?" styleClass="signup-text"/>
                <Button fx:id="backToLoginButton"
                        text="Log In"
                        styleClass="link-button"
                        onAction="#handleBackToLogin"/>
            </HBox>

        </VBox>

    </VBox>

</StackPane>
