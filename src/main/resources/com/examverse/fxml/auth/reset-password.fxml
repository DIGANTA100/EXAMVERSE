<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.examverse.controller.auth.ResetPasswordController"
           stylesheets="@../../css/auth.css"
           styleClass="auth-root">

    <!-- Background Gradient - Fills entire screen -->
    <VBox alignment="CENTER" styleClass="background-gradient"
          StackPane.alignment="CENTER"/>

    <!-- Card Container - Centers the reset password card -->
    <VBox alignment="CENTER" spacing="0"
          StackPane.alignment="CENTER">

        <!-- Reset Password Card -->
        <VBox alignment="CENTER" spacing="22" styleClass="login-card"
              maxWidth="520" minWidth="520">
            <padding>
                <Insets top="45" bottom="45" left="60" right="60"/>
            </padding>

            <!-- Header Section -->
            <VBox alignment="CENTER" spacing="10">
                <!-- Key Icon -->
                <HBox alignment="CENTER" styleClass="logo-container">
                    <VBox alignment="CENTER" styleClass="logo-circle">
                        <padding>
                            <Insets top="22" bottom="22" left="22" right="22"/>
                        </padding>
                        <Label text="🔑" style="-fx-font-size: 32px;"/>
                    </VBox>
                </HBox>

                <!-- Title -->
                <Label text="Reset Password" styleClass="auth-title"/>
                <Label fx:id="emailLabel" text="Code sent to your email"
                       styleClass="auth-subtitle" wrapText="true"
                       textAlignment="CENTER" maxWidth="380"/>
            </VBox>

            <!-- Message Label -->
            <Label fx:id="messageLabel" text="" styleClass="message-label"
                   wrapText="true" maxWidth="400" visible="false"/>

            <!-- Form Section -->
            <VBox spacing="16" styleClass="form-section" maxWidth="400">

                <!-- Verification Code Field -->
                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Verification Code" styleClass="field-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="timerLabel" text="⏱️ 10:00"
                               style="-fx-font-size: 12px; -fx-text-fill: #22d3ee;
                                      -fx-font-weight: 600;"/>
                    </HBox>
                    <TextField fx:id="codeField"
                               promptText="Enter 6-digit code"
                               styleClass="input-field"
                               style="-fx-font-size: 18px; -fx-font-weight: 600;
                                      -fx-text-fill: #22d3ee; -fx-alignment: center;
                                      -fx-letter-spacing: 4px;">
                        <padding>
                            <Insets top="14" bottom="14" left="16" right="16"/>
                        </padding>
                    </TextField>
                </VBox>

                <!-- New Password Field -->
                <VBox spacing="8">
                    <Label text="New Password" styleClass="field-label"/>
                    <PasswordField fx:id="newPasswordField"
                                   promptText="Create a new password (min 6 characters)"
                                   styleClass="input-field">
                        <padding>
                            <Insets top="14" bottom="14" left="16" right="16"/>
                        </padding>
                    </PasswordField>
                </VBox>

                <!-- Confirm Password Field -->
                <VBox spacing="8">
                    <Label text="Confirm New Password" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Re-enter your new password"
                                   styleClass="input-field">
                        <padding>
                            <Insets top="14" bottom="14" left="16" right="16"/>
                        </padding>
                    </PasswordField>
                </VBox>

            </VBox>

            <!-- Reset Password Button -->
            <Button fx:id="resetButton"
                    text="Reset Password"
                    styleClass="btn-login"
                    onAction="#handleResetPassword"
                    maxWidth="400">
                <padding>
                    <Insets top="16" bottom="16" left="35" right="35"/>
                </padding>
            </Button>

            <!-- Resend Code Section -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Didn't receive the code?" styleClass="signup-text"/>
                <Button fx:id="resendCodeButton"
                        text="Resend"
                        styleClass="link-button"
                        onAction="#handleResendCode"/>
            </HBox>

            <!-- Back to Login Link -->
            <Button text="← Back to Login"
                    styleClass="back-button"
                    onAction="#handleBackToLogin">
                <padding>
                    <Insets top="10" bottom="10" left="20" right="20"/>
                </padding>
            </Button>

        </VBox>

    </VBox>

</StackPane>
