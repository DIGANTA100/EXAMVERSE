<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="1080" prefWidth="1920" styleClass="auth-root" stylesheets="@../../css/auth.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examverse.controller.auth.SignupController">

    <!-- Background Gradient - Fills entire screen -->
    <VBox alignment="CENTER" styleClass="background-gradient" StackPane.alignment="CENTER" />

    <!-- ScrollPane for better content handling -->
    <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="auth-scroll-pane" StackPane.alignment="CENTER">

        <!-- Card Container - Centers the signup card -->
        <VBox alignment="CENTER" minHeight="1080" spacing="0">

            <!-- Signup Card - Fixed Width in Center -->
            <VBox alignment="CENTER" maxWidth="520" minWidth="520" spacing="18" styleClass="login-card">

                <padding>
                    <Insets bottom="35" left="60" right="60" top="35" />
                </padding>

                <!-- Header Section -->
                <VBox alignment="CENTER" spacing="6">
                    <HBox alignment="CENTER" styleClass="logo-container">
                        <VBox alignment="CENTER" styleClass="logo-circle">
                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>
                        </VBox>
                    </HBox>

                    <Label styleClass="auth-title" text="Create Account" />
                    <Label styleClass="auth-subtitle" text="Join ExamVerse and start your learning journey" />
                </VBox>

                <!-- Error / Success Message -->
                <Label fx:id="errorLabel" maxWidth="400" minHeight="0" styleClass="message-label" text="" wrapText="true" />

                <!-- Form Section -->
                <VBox maxWidth="400" spacing="14" styleClass="form-section">

                    <!-- Role Selection -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Sign Up As" />
                        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" promptText="Select your role" styleClass="role-combo">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </ComboBox>
                    </VBox>

                    <!-- Full Name -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Full Name" />
                        <TextField fx:id="fullNameField" nodeOrientation="LEFT_TO_RIGHT" promptText="Enter your full name" styleClass="input-field">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Username -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Username" />
                        <TextField fx:id="usernameField" promptText="Choose a username" styleClass="input-field">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Email Address" />
                        <TextField fx:id="emailField" promptText="Enter your email" styleClass="input-field">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Create a password (min 6 characters)" styleClass="input-field">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </PasswordField>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Confirm Password" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" styleClass="input-field">
                            <padding>
                                <Insets bottom="11" left="16" right="16" top="11" />
                            </padding>
                        </PasswordField>
                    </VBox>

                    <!-- Terms -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <CheckBox fx:id="termsCheckbox" styleClass="checkbox-custom" />
                        <Label styleClass="terms-text" text="I agree to the " />
                        <Button onAction="#handleTermsLink" styleClass="link-button-small" text="Terms &amp; Conditions" />
                    </HBox>

                </VBox>

                <!-- Signup Button -->
                <Button fx:id="signupButton" maxWidth="400" onAction="#handleSignup" styleClass="btn-login" text="Sign Up">
                    <padding>
                        <Insets bottom="14" left="35" right="35" top="14" />
                    </padding>
                </Button>

                <!-- Divider -->
                <HBox alignment="CENTER" maxWidth="400" spacing="12" styleClass="divider-container">
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS" />
                    <Label styleClass="divider-text" text="OR" />
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label styleClass="signup-text" text="Already have an account?" />
                    <Button fx:id="loginLinkButton" onAction="#handleLoginLink" styleClass="link-button" text="Log In" />
                </HBox>

                <!-- Community Text -->
                <Label styleClass="community-text" text="EXAMVERSE COMMUNITY" />

                <!-- Back -->
                <Button onAction="#handleBack" styleClass="back-button" text="← Back to Home">
                    <padding>
                        <Insets bottom="10" left="20" right="20" top="10" />
                    </padding>
                </Button>

            </VBox>

        </VBox>

    </ScrollPane>

</StackPane>
