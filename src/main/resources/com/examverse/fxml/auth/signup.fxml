<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.examverse.controller.auth.SignupController"
           stylesheets="@../../css/auth.css"
           styleClass="auth-root"
           prefWidth="1920"
           prefHeight="1080">

    <!-- Background Gradient - Fills entire screen -->
    <VBox alignment="CENTER" styleClass="background-gradient"
          StackPane.alignment="CENTER"/>

    <!-- ScrollPane for better content handling -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                styleClass="auth-scroll-pane"
                StackPane.alignment="CENTER">

        <!-- Card Container - Centers the signup card -->
        <VBox alignment="CENTER" spacing="0"
              minHeight="1080">

            <!-- Signup Card - Fixed Width in Center -->
            <VBox alignment="CENTER"
                  spacing="18"
                  styleClass="login-card"
                  maxWidth="520"
                  minWidth="520">

                <padding>
                    <Insets top="35" bottom="35" left="60" right="60"/>
                </padding>

                <!-- Header Section -->
                <VBox alignment="CENTER" spacing="6">
                    <HBox alignment="CENTER" styleClass="logo-container">
                        <VBox alignment="CENTER" styleClass="logo-circle">
                            <padding>
                                <Insets top="18" bottom="18" left="18" right="18"/>
                            </padding>
                        </VBox>
                    </HBox>

                    <Label text="Create Account" styleClass="auth-title"/>
                    <Label text="Join ExamVerse and start your learning journey"
                           styleClass="auth-subtitle"/>
                </VBox>

                <!-- Error / Success Message -->
                <Label fx:id="errorLabel"
                       text=""
                       styleClass="message-label"
                       wrapText="true"
                       maxWidth="400"
                       minHeight="0"/>

                <!-- Form Section -->
                <VBox spacing="14"
                      styleClass="form-section"
                      maxWidth="400">

                    <!-- Role Selection -->
                    <VBox spacing="5">
                        <Label text="Sign Up As" styleClass="field-label"/>
                        <ComboBox fx:id="roleComboBox"
                                  promptText="Select your role"
                                  styleClass="role-combo"
                                  maxWidth="Infinity">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </ComboBox>
                    </VBox>

                    <!-- Full Name -->
                    <VBox spacing="5">
                        <Label text="Full Name" styleClass="field-label"/>
                        <TextField fx:id="fullNameField"
                                   promptText="Enter your full name"
                                   styleClass="input-field">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Username -->
                    <VBox spacing="5">
                        <Label text="Username" styleClass="field-label"/>
                        <TextField fx:id="usernameField"
                                   promptText="Choose a username"
                                   styleClass="input-field">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label text="Email Address" styleClass="field-label"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   styleClass="input-field">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </TextField>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="5">
                        <Label text="Password" styleClass="field-label"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Create a password (min 6 characters)"
                                       styleClass="input-field">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </PasswordField>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="5">
                        <Label text="Confirm Password" styleClass="field-label"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Re-enter your password"
                                       styleClass="input-field">
                            <padding>
                                <Insets top="11" bottom="11" left="16" right="16"/>
                            </padding>
                        </PasswordField>
                    </VBox>

                    <!-- Terms -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <CheckBox fx:id="termsCheckbox" styleClass="checkbox-custom"/>
                        <Label text="I agree to the " styleClass="terms-text"/>
                        <Button text="Terms &amp; Conditions"
                                styleClass="link-button-small"/>
                    </HBox>

                </VBox>

                <!-- Signup Button -->
                <Button fx:id="signupButton"
                        text="Sign Up"
                        styleClass="btn-login"
                        onAction="#handleSignup"
                        maxWidth="400">
                    <padding>
                        <Insets top="14" bottom="14" left="35" right="35"/>
                    </padding>
                </Button>

                <!-- Divider -->
                <HBox alignment="CENTER"
                      spacing="12"
                      styleClass="divider-container"
                      maxWidth="400">
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                    <Label text="OR" styleClass="divider-text"/>
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Already have an account?"
                           styleClass="signup-text"/>
                    <Button fx:id="loginLinkButton"
                            text="Log In"
                            styleClass="link-button"
                            onAction="#handleLoginLink"/>
                </HBox>

                <!-- Community Text -->
                <Label text="EXAMVERSE COMMUNITY"
                       styleClass="community-text"/>

                <!-- Back -->
                <Button text="← Back to Home"
                        styleClass="back-button"
                        onAction="#handleBack">
                    <padding>
                        <Insets top="10" bottom="10" left="20" right="20"/>
                    </padding>
                </Button>

            </VBox>

        </VBox>

    </ScrollPane>

</StackPane>
