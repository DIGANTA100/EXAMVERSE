<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.examverse.controller.auth.LoginController"
      fx:id="rootPane"
      styleClass="root-pane"
      stylesheets="@../../css/auth.css"
      alignment="CENTER"
      spacing="20">

    <!-- Back Button -->
    <HBox alignment="TOP_LEFT">
        <Button text="← Back" onAction="#handleBack" styleClass="back-button">
            <HBox.margin>
                <Insets top="20" left="20"/>
            </HBox.margin>
        </Button>
    </HBox>

    <!-- Login Form Container -->
    <VBox styleClass="form-container" alignment="CENTER" spacing="25" maxWidth="450">
        <padding>
            <Insets top="40" right="50" bottom="40" left="50"/>
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="10">
            <Text text="Welcome Back" styleClass="form-title"/>
            <Text text="Login to access your account" styleClass="form-subtitle"/>
        </VBox>

        <!-- Role Selection Dropdown - FIXED! -->
        <VBox spacing="8">
            <Label text="Login As" styleClass="field-label"/>
            <ComboBox fx:id="roleComboBox" promptText="Select your role" styleClass="role-combo" maxWidth="Infinity"/>
        </VBox>

        <!-- Username/Email Field -->
        <VBox spacing="8">
            <Label text="Username or Email" styleClass="field-label"/>
            <TextField fx:id="usernameField"
                       promptText="Enter your username or email"
                       styleClass="input-field"/>
        </VBox>

        <!-- Password Field -->
        <VBox spacing="8">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="input-field"/>
        </VBox>

        <!-- Remember Me & Forgot Password -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <CheckBox fx:id="rememberMeCheckbox" text="Remember me" styleClass="remember-checkbox"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword" styleClass="forgot-link"/>
        </HBox>

        <!-- Error/Success Label -->
        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false"/>

        <!-- Login Button -->
        <Button fx:id="loginButton"
                text="Log In"
                onAction="#handleLogin"
                styleClass="primary-button"
                maxWidth="Infinity"
                minHeight="45"/>

        <!-- Signup Link -->
        <HBox alignment="CENTER" spacing="5">
            <Text text="Don't have an account?" styleClass="signup-text"/>
            <Hyperlink text="Sign Up" onAction="#handleSignupLink" styleClass="signup-link"/>
        </HBox>

        <!-- Admin Credentials Hint (for testing) -->
        <VBox alignment="CENTER" spacing="5" style="-fx-padding: 20 0 0 0;">
            <Text text="💡 Test Credentials" style="-fx-fill: #64748b; -fx-font-size: 11px;"/>
            <Text text="Admin: admin / admin123" style="-fx-fill: #64748b; -fx-font-size: 10px;"/>
        </VBox>

    </VBox>

</VBox>
