<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.examverse.controller.auth.LoginController"
           stylesheets="@../../css/auth.css"
           styleClass="auth-root"
           prefWidth="1920"
           prefHeight="1080">

    <!-- Background Gradient - Fills entire screen -->
    <VBox alignment="CENTER" styleClass="background-gradient"
          StackPane.alignment="CENTER"/>

    <!-- Card Container - Centers the login card -->
    <VBox alignment="CENTER" spacing="0"
          StackPane.alignment="CENTER">

        <!-- Login Card - Fixed Width in Center -->
        <VBox alignment="CENTER"
              spacing="20"
              styleClass="login-card"
              maxWidth="520"
              minWidth="520">

            <padding>
                <Insets top="40" bottom="40" left="60" right="60"/>
            </padding>

            <!-- Header Section -->
            <VBox alignment="CENTER" spacing="8">
                <HBox alignment="CENTER" styleClass="logo-container">
                    <VBox alignment="CENTER" styleClass="logo-circle">
                        <padding>
                            <Insets top="20" bottom="20" left="20" right="20"/>
                        </padding>
                    </VBox>
                </HBox>

                <Label text="Welcome Back" styleClass="auth-title"/>
                <Label text="Login to access your account"
                       styleClass="auth-subtitle"/>
            </VBox>

            <!-- Error / Success Message -->
            <Label fx:id="errorLabel"
                   text=""
                   styleClass="message-label"
                   wrapText="true"
                   maxWidth="400"
                   visible="false"/>

            <!-- Form Section -->
            <VBox spacing="16"
                  styleClass="form-section"
                  maxWidth="400">

                <!-- Role Selection -->
                <VBox spacing="6">
                    <Label text="Login As" styleClass="field-label"/>
                    <ComboBox fx:id="roleComboBox"
                              promptText="Select your role"
                              styleClass="role-combo"
                              maxWidth="Infinity">
                        <padding>
                            <Insets top="12" bottom="12" left="16" right="16"/>
                        </padding>
                    </ComboBox>
                </VBox>

                <!-- Username/Email Field -->
                <VBox spacing="6">
                    <Label text="Username or Email" styleClass="field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username or email"
                               styleClass="input-field">
                        <padding>
                            <Insets top="12" bottom="12" left="16" right="16"/>
                        </padding>
                    </TextField>
                </VBox>

                <!-- Password Field -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="input-field">
                        <padding>
                            <Insets top="12" bottom="12" left="16" right="16"/>
                        </padding>
                    </PasswordField>
                </VBox>

                <!-- Remember Me & Forgot Password -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <CheckBox fx:id="rememberMeCheckbox"
                              text="Remember me"
                              styleClass="checkbox-custom"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Forgot Password?"
                            onAction="#handleForgotPassword"
                            styleClass="link-button-small"/>
                </HBox>

            </VBox>

            <!-- Login Button -->
            <Button fx:id="loginButton"
                    text="Log In"
                    styleClass="btn-login"
                    onAction="#handleLogin"
                    maxWidth="400">
                <padding>
                    <Insets top="16" bottom="16" left="35" right="35"/>
                </padding>
            </Button>

            <!-- Divider -->
            <HBox alignment="CENTER"
                  spacing="12"
                  styleClass="divider-container"
                  maxWidth="400">
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                <Label text="OR" styleClass="divider-text"/>
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Signup Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       styleClass="signup-text"/>
                <Button text="Sign Up"
                        styleClass="link-button"
                        onAction="#handleSignupLink"/>
            </HBox>

            <!-- Community Text -->
            <Label text="EXAMVERSE COMMUNITY"
                   styleClass="community-text"/>

            <!-- Back Button -->
            <Button text="← Back to Home"
                    styleClass="back-button"
                    onAction="#handleBack">
                <padding>
                    <Insets top="10" bottom="10" left="20" right="20"/>
                </padding>
            </Button>

        </VBox>

    </VBox>

</StackPane>
