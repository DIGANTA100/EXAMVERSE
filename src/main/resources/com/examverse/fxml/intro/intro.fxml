<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.examverse.controller.intro.IntroController"
           stylesheets="@../../css/intro.css"
           styleClass="root-pane">

    <!-- Background Video Layer -->
    <MediaView fx:id="mediaView"
               fitWidth="1920"
               fitHeight="1080"
               preserveRatio="true"
               smooth="true"
               styleClass="media-view"/>

    <!-- Overlay Layer with Get Started Button -->
    <VBox alignment="CENTER"
          spacing="0"
          styleClass="overlay-container">

        <!-- Spacer to push button down (after "Redefining Academic Intelligence" text) -->
        <!-- The video text appears at ~60% height, button should be below that -->
        <VBox VBox.vgrow="ALWAYS" minHeight="620"/>

        <!-- Get Started Button Container -->
        <VBox alignment="CENTER" spacing="30" styleClass="button-container">

            <!-- Get Started Button -->
            <Button fx:id="getStartedButton"
                    text="GET STARTED"
                    styleClass="get-started-button"
                    onAction="#handleGetStarted">
                <VBox.margin>
                    <Insets top="50" bottom="40"/>
                </VBox.margin>
            </Button>

        </VBox>

        <!-- Bottom Spacer -->
        <VBox VBox.vgrow="ALWAYS" minHeight="100"/>

    </VBox>

</StackPane>
