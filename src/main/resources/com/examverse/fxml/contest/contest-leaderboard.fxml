<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.examverse.controller.contest.LeaderboardController"
            style="-fx-background-color:#0a0a1a;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color:#0f0f23; -fx-border-color:#1e293b; -fx-border-width:0 0 1 0;">
            <padding><Insets top="16" right="30" bottom="16" left="30"/></padding>

            <Button fx:id="backBtn" text="← Back" onAction="#handleBack"
                    style="-fx-background-color:#1e293b; -fx-text-fill:#94a3b8;
                           -fx-background-radius:8; -fx-padding:8 16;"/>

            <Label style="-fx-text-fill:#fbbf24; -fx-font-size:22px; -fx-font-weight:bold;">
                🏆  Global Leaderboard
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- My stats pill -->
            <HBox alignment="CENTER" spacing="16"
                  style="-fx-background-color:#1e293b; -fx-background-radius:10; -fx-padding:8 20;">
                <Label fx:id="myRankLabel" text="Your Rank: —"
                       style="-fx-text-fill:#94a3b8; -fx-font-size:13px;"/>
                <Label fx:id="myRatingLabel" text="Rating: —"
                       style="-fx-text-fill:#7c3aed; -fx-font-size:15px; -fx-font-weight:bold;"/>
                <Label fx:id="myTitleLabel" text=""
                       style="-fx-font-size:13px;"/>
            </HBox>

            <!-- Search -->
            <TextField fx:id="searchField" promptText="🔍  Search player..."
                       style="-fx-background-color:#1e293b; -fx-text-fill:#e2e8f0;
                              -fx-prompt-text-fill:#475569; -fx-background-radius:8;
                              -fx-padding:8 14; -fx-pref-width:200;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background:#0a0a1a; -fx-background-color:#0a0a1a;">
            <VBox fx:id="rootVBox" spacing="0">
                <padding><Insets top="24" right="40" bottom="40" left="40"/></padding>
                <VBox fx:id="leaderboardContent" spacing="4"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
