<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.examverse.controller.admin.ContestManagerController"
            style="-fx-background-color:#0a0a1a;">

    <!-- ═══ TOP HEADER ═══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color:#0f0f23; -fx-border-color:#1e293b; -fx-border-width:0 0 1 0;">
            <padding><Insets top="18" right="30" bottom="18" left="30"/></padding>

            <Button fx:id="backBtn" text="← Back" onAction="#handleBack"
                    style="-fx-background-color:#1e293b; -fx-text-fill:#94a3b8;
                           -fx-background-radius:8; -fx-padding:8 16;"/>

            <Label style="-fx-text-fill:#7c3aed; -fx-font-size:22px; -fx-font-weight:bold;">
                🏆  Contest Manager
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="createContestBtn" text="➕  Create Contest"
                    onAction="#handleCreateContest"
                    style="-fx-background-color:#7c3aed; -fx-text-fill:#fff;
                           -fx-font-weight:bold; -fx-background-radius:10;
                           -fx-padding:10 24; -fx-font-size:14px;"/>
        </HBox>
    </top>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background:#0a0a1a; -fx-background-color:#0a0a1a;">
            <VBox fx:id="mainContent" spacing="0">
                <padding><Insets top="30" right="40" bottom="40" left="40"/></padding>

                <!-- Page title -->
                <Label text="All Contests"
                       style="-fx-text-fill:#e2e8f0; -fx-font-size:18px; -fx-font-weight:bold;">
                    <VBox.margin><Insets bottom="20"/></VBox.margin>
                </Label>

                <!-- Dynamic contest cards go here -->
                <VBox fx:id="contestListContainer" spacing="16"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
